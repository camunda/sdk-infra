{
  "name": "@camunda8/sdk-infra",
  "version": "0.0.0-semantic-release",
  "description": "Shared infrastructure for Camunda SDK repositories",
  "repository": {
    "type": "git",
    "url": "https://github.com/camunda/sdk-infra.git"
  },
  "license": "Apache-2.0",
  "files": [
    "configs/",
    "scripts/",
    "schema/",
    "docker/",
    "policies/",
    "operations-baseline.json"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs"
  },
  "devDependencies": {
    "semantic-release": "^25.0.0"
  },
  "release": {
    "branches": ["main"],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  }
}
