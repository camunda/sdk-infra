{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SDK Operation Map",
  "description": "Maps OpenAPI operationIds to example code regions for display in API docs.",
  "type": "object",
  "additionalProperties": {
    "type": "array",
    "minItems": 1,
    "items": {
      "type": "object",
      "required": ["file", "region", "label"],
      "properties": {
        "file": {
          "type": "string",
          "description": "Relative path to the example file (from examples/ directory).",
          "minLength": 1
        },
        "region": {
          "type": "string",
          "description": "Region tag name within the file.",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "description": "Human-readable label for the example (displayed in docs).",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "createProcessInstance": [
        {
          "file": "client.py",
          "region": "CreateProcessInstance",
          "label": "Create a process instance"
        }
      ],
      "getTopology": [
        {
          "file": "admin_operations.py",
          "region": "GetTopology",
          "label": "Get cluster topology"
        }
      ]
    }
  ]
}
